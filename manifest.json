{
  "manifest_version": 3,
  "name": "Save as Image",
  "version": "1.2.0",
  "description": "Web sitelerindeki görselleri sağ tıklayarak JPG, PNG veya WEBP formatında kaydetmenizi sağlar.",
  "permissions": [
    "contextMenus",
    "downloads",
    "offscreen",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "minimum_chrome_version": "109",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
